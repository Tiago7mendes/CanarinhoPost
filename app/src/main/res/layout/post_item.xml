<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#FFDF00" />

        <ImageView
            android:id="@+id/imgPost"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:contentDescription="Imagem do post" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtDescricao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:lineSpacingMultiplier="1.5"
                android:text="Descrição do post" />

            <!-- Botão editar — só aparece para o autor -->
            <ImageButton
                android:id="@+id/btnEditar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar post"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                app:tint="#009C3B" />

            <!-- Botão deletar — só aparece para o autor -->
            <ImageButton
                android:id="@+id/btnDeletar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Deletar post"
                android:visibility="gone"
                app:tint="#E53935" />

        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginStart="14dp"
            android:layout_marginBottom="10dp"
            android:background="#009C3B" />

    </LinearLayout>

</androidx.cardview.widget.CardView>