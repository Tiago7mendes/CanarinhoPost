<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="top">

    <androidx.cardview.widget.CardView
        android:layout_width="38dp"
        android:layout_height="38dp"
        app:cardCornerRadius="19dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/imgFotoComentario"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/empty_profile"
            android:contentDescription="Foto do comentarista" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:background="#F4F4F4"
        android:padding="10dp">

        <TextView
            android:id="@+id/txtUsernameComentario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#002776"
            android:text="username" />

        <TextView
            android:id="@+id/txtTextoComentario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#1A1A1A"
            android:layout_marginTop="2dp"
            android:lineSpacingMultiplier="1.4"
            android:text="Texto do comentário" />

    </LinearLayout>

</LinearLayout>