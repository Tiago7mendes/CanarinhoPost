<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F4">

    <!-- Header verde -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#009C3B"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Foto de perfil clicável — vai para ProfileActivity -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoPerfil"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/imgFotoPerfil"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/empty_profile"
                android:scaleType="centerCrop"
                android:contentDescription="Foto de perfil" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txtUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="username"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFDF00" />

            <TextView
                android:id="@+id/txtNomeCompleto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome Completo"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF" />
        </LinearLayout>

        <!-- Logo canarinho como botão atualizar -->
        <ImageButton
            android:id="@+id/btnCarregarFeed"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/canarinho"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Atualizar feed"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- Faixa amarela com busca por cidade -->
    <LinearLayout
        android:id="@+id/bannerCopa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFDF00"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textSize="16sp"
            android:layout_marginEnd="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Buscar por cidade..."
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            app:boxStrokeColor="#009C3B"
            app:boxBackgroundColor="#FFFFFF"
            android:layout_marginEnd="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtBuscarCidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:imeOptions="actionSearch"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Buscar"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#009C3B"
            android:paddingHorizontal="12dp" />

        <ImageButton
            android:id="@+id/btnLimparBusca"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Limpar busca"
            android:layout_marginStart="4dp"
            android:visibility="gone"
            app:tint="#002776" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#009C3B"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/bannerCopa"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/bannerCopa"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FAB novo post -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnNovoPost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Novo post"
        app:backgroundTint="#009C3B"
        app:tint="#FFDF00"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>